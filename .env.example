# =====================================================================
# Telegram AI Core — пример переменных окружения
# Скопируй файл в .env и заполни нужные значения. .env не коммитится.
# =====================================================================

# --- Окружение и сервер ---
APP_ENV=local
LOG_LEVEL=INFO
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
PORT=8000

# --- Telegram ---
# Если пусто — polling не стартует, FastAPI продолжает работать.
TELEGRAM_BOT_TOKEN=
TELEGRAM_MODE=polling
# Webhook (на MVP не активен, но переменные заложены)
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=

# --- CryptoPanic (опционально; без ключа используется RSS fallback) ---
CRYPTOPANIC_API_KEY=

# --- OpenRouter ---
# Если пусто — бот ответит, что ключ не настроен.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_SITE_URL=https://example.com
OPENROUTER_APP_NAME=Telegram AI Core

# --- Лимиты и таймауты ---
LLM_TIMEOUT_SECONDS=120
RATE_LIMIT_MESSAGES=30
RATE_LIMIT_WINDOW_SECONDS=3600
DAILY_USER_MESSAGE_LIMIT=0
MONTHLY_GLOBAL_MESSAGE_LIMIT=0
AGENT_PROMPT_MAX_LENGTH=8000
TELEGRAM_DRAFT_UPDATE_INTERVAL_MS=500
TELEGRAM_STREAM_MIN_CHARS_DELTA=24
TELEGRAM_STREAM_DRAFT_ENABLED=true
TELEGRAM_STREAM_EDIT_FALLBACK_ENABLED=true

# --- PostgreSQL ---
# Если DATABASE_URL пусто — собирается из POSTGRES_* (для docker compose).
DATABASE_URL=
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=telegram_ai_core
POSTGRES_USER=telegram_ai_core
POSTGRES_PASSWORD=telegram_ai_core_password

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Admin / runtime settings ---
# Access mode: public, allowlist или admin_only.
BOT_ACCESS_MODE=public
# CSV Telegram user-id, которым разрешён доступ при BOT_ACCESS_MODE=allowlist.
ALLOWED_TELEGRAM_USER_IDS=
# CSV Telegram user-id администраторов (/settings, /debug).
ADMIN_TELEGRAM_IDS=
# Legacy alias: пока поддерживается для обратной совместимости.
ADMIN_TELEGRAM_USER_IDS=
# Fernet-ключ для шифрования OpenRouter API-ключа в таблице app_settings.
# Сгенерировать: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SETTINGS_ENCRYPTION_KEY=
